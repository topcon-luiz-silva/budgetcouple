# BudgetCouple Frontend - Production Environment Variables
# Copy to .env.production and fill with actual values

# API Base URL (Render backend)
VITE_API_URL=https://budgetcouple-api.onrender.com/api/v1

# Supabase (if needed for direct storage access)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Analytics
VITE_ENABLE_ANALYTICS=true

# Optional: Feature flags
VITE_ENABLE_WEBPUSH=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
