# Supabase PostgreSQL
DATABASE_URL=Host=aws-0-sa-east-1.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.xxxx;Password=YOUR_PASSWORD;Ssl Mode=Require;Trust Server Certificate=true

# JWT
JWT_ISSUER=BudgetCouple
JWT_AUDIENCE=BudgetCouple
JWT_SECRET=change-me-to-a-long-random-secret-with-at-least-64-chars
JWT_EXPIRES_MINUTES=60

# Supabase Storage (anexos / imports)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=budgetcouple

# Notificações (Fase 9)
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
WEBPUSH_VAPID_PUBLIC=
WEBPUSH_VAPID_PRIVATE=

# Observabilidade
SENTRY_DSN=

ASPNETCORE_ENVIRONMENT=Development
